pipeline {
    agent any

    stages {

        stage('Setup Python Environment') {
            steps {
                sh '''
                    python3 -m venv .venv
                    . .venv/bin/activate
                    python -m pip install --upgrade pip

                    cd backend
                    pip install -r requirements.txt
                '''
            }
        }

        stage('Verify Django Project') {
            steps {
                sh '''
                    . .venv/bin/activate

                    cd backend
                    python manage.py check
                '''
            }
        }

    }

    post {
        always {
            script {
                def durationSeconds = (currentBuild.duration / 1000) as int

                withEnv([
                    "API_URL=http://host.docker.internal:8000/api/builds/",
                    "BUILD_NUMBER=${env.BUILD_NUMBER}",
                    "JOB_NAME=${env.JOB_NAME}",
                    "BRANCH_NAME=${env.BRANCH_NAME ?: 'main'}",
                    "BUILD_STATUS=${currentBuild.currentResult}",
                    "BUILD_DURATION=${durationSeconds}"
                ]) {
                    sh '''
                        . .venv/bin/activate
                        cd backend
                        python scripts/send_build.py
                    '''
                }
            }
        }
    }
}