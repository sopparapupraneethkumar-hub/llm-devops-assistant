pipeline {
    agent any

    stages {
        stage('Setup Python Environment') {
            steps {
                sh '''
                    python3 -m venv .venv
                    . .venv/bin/activate
                    pip install --upgrade pip
                    pip install -r requirements.txt
                '''
            }
        }

        stage('Verify Django Project') {
            steps {
                sh '''
                    . .venv/bin/activate
                    cd backend
                    python manage.py check
                '''
            }
        }
    }
}